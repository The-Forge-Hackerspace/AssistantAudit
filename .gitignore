# ==============================================================================
# AssistantAudit — .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tools (vendored external tools at repo root — not source code subdirs)
/tools/
.tools/
./tool

# Environment
.env
.env.*

# Wiki
wiki/

# Database
instance/
*.db
*.sqlite3

# Uploads & logs
uploads/
logs/
data/
*.log

# Monkey365
monkey365_output/
integrations/monkey365/

# Node (frontend)
node_modules/
.next/
frontend/tmp/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker
docker-compose.override.yml

# Alembic versions are tracked in git


# Tests
.pytest_cache/
htmlcov/
.coverage

# AI assistant metadata (Claude Code, GitHub Copilot, etc.)
.claude/
CLAUDE.md
**/CLAUDE.md
AGENTS.md
**/AGENTS.md
.copilot/
.github/copilot*
*.copilot*