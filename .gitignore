# ==============================================================================
# AssistantAudit — .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tools
tools/
# Environment
.env
.env.local
.env.production

# Wiki
wiki/

# Database
instance/
*.db
*.sqlite3

# Uploads & logs
uploads/
logs/
data/
*.log

# Monkey365
monkey365_output/
integrations/monkey365/

# PingCastle
tools/pingcastle/

# Node (future frontend)
node_modules/
.next/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker
docker-compose.override.yml

# Alembic
backend/alembic/versions/*.py
!backend/alembic/versions/.gitkeep

# Tests
.pytest_cache/
htmlcov/
.coverage
