# ==============================================================================
# AssistantAudit — .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tools (vendored external code at repo root — ne pas versionner le contenu)
/tools/*
!/tools/.gitkeep

# Environment
.env
.env.*

# Database
instance/
*.db
*.sqlite3

# Uploads, logs, runtime data
uploads/
logs/
data/
!backend/app/data/
*.log

# Node (frontend)
node_modules/
.next/
frontend/tmp/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker
docker-compose.override.yml

# Tests
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
/playwright-results/.env.playwright
playwright-report/
playwright-results/
test-results/

# Manual test results
tests/manual/results/

# AI assistant local state (NOT versioned — chacun sa machine)
.claude/
.copilot/
.github/copilot*
*.copilot*
.hex-skills/
GEMINI.md
**/GEMINI.md

# Local archives & audit reports (générés localement, hors-repo)
.archive/
docs/project/.audit/
docs/project/.local/
