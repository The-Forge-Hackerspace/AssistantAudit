# AssistantAudit - Variables d'Environnement
# Ce fichier est automatiquement copié vers .env par start.ps1 si .env n'existe pas

# Clé secrète (générée automatiquement par start.ps1 si vide)
SECRET_KEY=change-me-in-production

# Base de données (SQLite par défaut, PostgreSQL recommandé en production)
# DATABASE_URL=postgresql://user:password@localhost:5432/assistantaudit
DATABASE_URL=sqlite:///instance/assistantaudit.db

# Environnement: development, testing, production
ENV=development

# Uploads
# UPLOAD_FOLDER=/chemin/vers/uploads
# MAX_CONTENT_LENGTH=16777216

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Logging (LOG_LEVEL=DEBUG en mode --dev)
LOG_LEVEL=INFO
# LOG_FILE=/chemin/vers/logs/assistantaudit.log

# Nmap
NMAP_TIMEOUT=600

# Monkey365 (automatiquement configuré par start.ps1)
# MONKEY365_PATH sera défini automatiquement vers tools/monkey365/Invoke-Monkey365.ps1
# MONKEY365_PATH=
MONKEY365_TIMEOUT=600

# Données / Stockage
DATA_DIR=./data

# --- Chiffrement au repos (AES-256-GCM) ---
# Générer avec : python -c 'import os; print(os.urandom(32).hex())'
# Laisser vide = chiffrement désactivé (dev uniquement, INTERDIT en production)
ENCRYPTION_KEY=
FILE_ENCRYPTION_KEY=

# --- Certificats mTLS (communication serveur <-> agent) ---
# Chemins relatifs au dossier backend/
CA_CERT_PATH=certs/ca.pem
CA_KEY_PATH=certs/ca.key
