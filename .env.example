# ============================================================================
# AssistantAudit — Variables d'Environnement
# ============================================================================
#
# Ce fichier documente TOUTES les variables de configuration du projet.
#
# Utilisation :
#   1. Copier ce fichier vers .env :  cp .env.example .env
#   2. Remplir les valeurs marquées "change-me-in-production"
#   3. Ne JAMAIS committer le fichier .env (il est dans .gitignore)
#
# Note : start.ps1 copie automatiquement ce fichier vers .env si .env
#        n'existe pas encore.
#
# ============================================================================


# ============================================================================
# SECTION 1 — SECRETS CRITIQUES (obligatoires en production)
# ============================================================================

# SECRET_KEY — Clé secrète pour la signature des tokens JWT
# ─────────────────────────────────────────────────────────
# Obligatoire en : production, staging, preprod (erreur fatale si absente)
# En développement : auto-générée si vide (non persistante entre redémarrages)
# Longueur minimale : 32 caractères (vérifiée par config.py)
#
# Générer avec :
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
#
SECRET_KEY=change-me-in-production

# ADMIN_PASSWORD — Mot de passe de l'administrateur initial (bootstrap Docker)
# ─────────────────────────────────────────────────────────────────────────────
# Utilisé par docker_entrypoint.py pour créer le compte admin au premier
# démarrage du conteneur. Non utilisé en dehors de Docker.
# Exigences : mot de passe fort, minimum 12 caractères recommandé.
#
ADMIN_PASSWORD=change-me-in-production


# ============================================================================
# SECTION 2 — CLÉS DE CHIFFREMENT (AES-256-GCM)
# ============================================================================
# Voir aussi : validation dans backend/app/core/config.py (TOS-61)

# ENCRYPTION_KEY — Clé de chiffrement des colonnes sensibles en base
# ──────────────────────────────────────────────────────────────────
# Format : 64 caractères hexadécimaux (= 32 bytes = 256 bits)
# Obligatoire en : production, staging, preprod (erreur fatale si absente)
# En développement : chiffrement désactivé si vide
#
# Générer avec :
#   python -c 'import os; print(os.urandom(32).hex())'
#
ENCRYPTION_KEY=

# FILE_ENCRYPTION_KEY — Clé enveloppe (KEK) pour le chiffrement des fichiers
# ────────────────────────────────────────────────────────────────────────────
# Format : 64 caractères hexadécimaux (= 32 bytes = 256 bits)
# Rôle : Key Encryption Key (KEK) pour l'envelope encryption des fichiers
#        sur disque. Chaque fichier possède sa propre DEK chiffrée par cette KEK.
# Obligatoire en : production, staging, preprod (erreur fatale si absente)
# En développement : chiffrement fichiers désactivé si vide
#
# Générer avec :
#   python -c 'import os; print(os.urandom(32).hex())'
#
# Rotation : voir backend/scripts/rotate_kek.py
#
FILE_ENCRYPTION_KEY=


# ============================================================================
# SECTION 3 — BASE DE DONNÉES
# ============================================================================

# POSTGRES_PASSWORD — Mot de passe PostgreSQL (Docker)
# ────────────────────────────────────────────────────
# Doit correspondre à la valeur dans docker-compose.yml.
# En production : utiliser un mot de passe fort et unique.
#
POSTGRES_PASSWORD=changeme

# POSTGRES_USER et POSTGRES_DB sont définis dans docker-compose.yml
# (par défaut : assistantaudit / assistantaudit).
# Les redéfinir ici si besoin de surcharger docker-compose.

# DATABASE_URL — Chaîne de connexion à la base de données
# ────────────────────────────────────────────────────────
# SQLite par défaut en développement, PostgreSQL recommandé en production.
# En production : utiliser des identifiants forts et une connexion chiffrée (sslmode=require).
#
# Exemples :
#   PostgreSQL : postgresql://user:password@localhost:5432/assistantaudit
#   SQLite     : sqlite:///instance/assistantaudit.db
#
DATABASE_URL=sqlite:///instance/assistantaudit.db


# ============================================================================
# SECTION 4 — CONFIGURATION APPLICATION
# ============================================================================

# ENV — Environnement d'exécution
# Valeurs possibles : development, testing, staging, preprod, production
ENV=development

# DEMO — Injection automatique des données de démonstration au démarrage Docker
# ───────────────────────────────────────────────────────────────────────────────
DEMO=false  # true|1|yes|on → exécute scripts/seed_demo.py après migrations (idempotent)
# → À réserver au staging / démo. Ne JAMAIS activer en production.

# --- Uploads ---
# UPLOAD_DIR=/chemin/vers/uploads
# MAX_UPLOAD_SIZE_MB=16

# --- Pagination ---
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# --- Logging (LOG_LEVEL=DEBUG recommandé en mode --dev) ---
LOG_LEVEL=INFO
# LOG_FILE=/chemin/vers/logs/assistantaudit.log

# --- Outils intégrés ---
NMAP_TIMEOUT=600

# Monkey365 (automatiquement configuré par start.ps1)
# MONKEY365_PATH sera défini automatiquement vers tools/monkey365/Invoke-Monkey365.ps1
# MONKEY365_PATH=
MONKEY365_TIMEOUT=600

# --- Données / Stockage ---
DATA_DIR=./data

# --- Certificats mTLS (communication serveur <-> agent) ---
# Chemins relatifs au dossier backend/
CA_CERT_PATH=certs/ca.pem
CA_KEY_PATH=certs/ca.key
CRL_PATH=certs/crl.pem

# --- CORS (origines autorisées, séparées par virgule) ---
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Reverse proxy (NPMPlus en prod, Caddy en staging) ---
# uvicorn n'accepte X-Forwarded-Proto/For (HSTS, rate-limit IP) que depuis les
# IPs listees ici. Defaut '*' = backend accessible uniquement via le proxy.
# Restreindre a l'IP du proxy si le port 8000 devient public.
# FORWARDED_ALLOW_IPS=10.0.0.5

# --- Sentry (monitoring erreurs, optionnel) ---
# SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_TRACING_ENABLED=false
# SENTRY_TRACES_SAMPLE_RATE=0.1


# ============================================================================
# CHECKLIST PRODUCTION
# ============================================================================
# Avant de déployer en production, vérifier que :
#
#   [ ] SECRET_KEY est défini (>= 32 caractères, généré aléatoirement)
#   [ ] ADMIN_PASSWORD est un mot de passe fort et unique
#   [ ] ENCRYPTION_KEY est défini (64 hex chars)
#   [ ] FILE_ENCRYPTION_KEY est défini (64 hex chars)
#   [ ] POSTGRES_PASSWORD est un mot de passe fort et unique
#   [ ] DATABASE_URL pointe vers PostgreSQL (pas SQLite)
#   [ ] ENV=production
#   [ ] Ce fichier .env n'est PAS commité dans le dépôt git
#   [ ] Les clés sont stockées dans un gestionnaire de secrets (Vault, etc.)
#
# ============================================================================
