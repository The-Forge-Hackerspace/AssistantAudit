# AssistantAudit - Variables d'Environnement
# Copiez ce fichier vers .env et adaptez les valeurs

# Clé secrète Flask (générer avec: python -c "import os; print(os.urandom(32).hex())")
SECRET_KEY=change-me-in-production

# Base de données (SQLite par défaut, PostgreSQL recommandé en production)
# DATABASE_URL=postgresql://user:password@localhost:5432/assistantaudit
# DATABASE_URL=sqlite:///instance/assistantaudit.db

# Environnement: development, testing, production
FLASK_ENV=development

# Uploads
# UPLOAD_FOLDER=/chemin/vers/uploads
# MAX_CONTENT_LENGTH=16777216

# Pagination
ITEMS_PER_PAGE=20

# Logging
LOG_LEVEL=INFO
# LOG_FILE=/chemin/vers/logs/assistantaudit.log

# Nmap
NMAP_TIMEOUT=600

# PingCastle (automatically configured by start.ps1)
# PINGCASTLE_PATH=/path/to/PingCastle.exe
# PINGCASTLE_TIMEOUT=300
# PINGCASTLE_OUTPUT_DIR=./backend/uploads/pingcastle

# Monkey365
# MONKEY365_PATH=/path/to/Invoke-Monkey365.ps1
